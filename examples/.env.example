# Trace storage backend — sqlite persists to ~/.longtracer/traces.db by default
# Options: sqlite (default) | memory | mongo | postgres | redis
# TRACE_CACHE_BACKEND=sqlite

# MongoDB (uncomment to use)
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DATABASE=longtracer
# MONGODB_COLLECTION_TRACES=traces
# MONGODB_COLLECTION_RUNS=runs

# PostgreSQL (uncomment to use)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=longtracer
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=

# Redis (uncomment to use)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Ollama LLM (default: llama3.1 at localhost)
# OLLAMA_MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434

# Embedding model (default: BAAI/bge-small-en-v1.5)
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ChromaDB collection name (default: citation_guard for backward compat)
# CHROMA_COLLECTION=longtracer
